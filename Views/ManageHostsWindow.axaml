<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500" Width="800" Height="500" Icon="/Assets/Images/Logo.ico"
        x:Class="Quack.sh.Views.ManageHostsWindow"
        Title="Manage Hosts">
        <Border Background="{DynamicResource BackgroundColor}">
                <Grid>
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" x:Name="Sidebar" Background="{DynamicResource SurfaceColor}">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="50"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" x:Name="ParentPanel" Orientation="Vertical" Spacing="10" Margin="10">
                                        
                                </StackPanel>
                                <Grid Grid.Row="1" Margin="10">
                                        <Button Content="Add connection" Click="AddConnection_OnClick" Height="35" VerticalAlignment="Center"/>
                                                
                                </Grid>
                        </Grid>
                        <Grid Grid.Column="1">
                                <StackPanel Spacing="10" Margin="16" x:Name="BoxPanel" IsVisible="False">
                                        <TextBlock Text="Host Name"/>
                                        <TextBox Watermark="Debian Server" x:Name="NameTextBox"/>
                                        <TextBlock Text="Host"/>
                                        <TextBox Watermark="192.168.178.43" x:Name="HostTextBox"/>
                                        <TextBlock Text="Port"/>
                                        <TextBox Watermark="22" x:Name="PortTextBox"/>
                                        <TextBlock Text="Username"/>
                                        <TextBox Watermark="root" x:Name="UserTextBox"/>
                                        <TextBlock Text="Password"/>
                                        <TextBox Watermark="iLoveAdmins" PasswordChar="•" x:Name="PasswordTextBox"/>
                
                                        <Button x:Name="BoxPanelButton" Content="" Background="MediumTurquoise"/>
                                </StackPanel>
                        </Grid>
                </Grid>
        </Border>
</Window>
