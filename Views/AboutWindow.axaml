<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="350" Width="400" Height="350"
        x:Class="Quack.sh.Views.AboutWindow"
        Title="About Quack.sh">
        <Border Background="{DynamicResource BackgroundColor}">
                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                
                
            
                        <Image Grid.Row="0" Source="{SvgImage /Assets/Images/logo_long-192x128.svg}" Height="128" Width="192"></Image>
                        <TextBlock TextAlignment="Justify" Grid.Row="1"
                                   Text="Quack.sh is an Open-Source SSH-Client made as a hobby project by a student. This idea has spread because I love to tinker with Servers and love homelabbing, and coding of course! If you like this project feel free to leave a star on its repo ♥" Margin="30" TextWrapping="Wrap"></TextBlock>
                </Grid>
        </Border>
</Window>
