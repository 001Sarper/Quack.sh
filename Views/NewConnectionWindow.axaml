<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="350" CanResize="False" MaxHeight="350" MaxWidth="400"
        x:Class="Quack.sh.NewConnectionWindow"
        Title="Add a new Connection">
        <Border Background="{DynamicResource BackgroundColor}">
                <StackPanel Spacing="10" Margin="16">
                        <TextBlock Text="Host"/>
                        <TextBox Watermark="192.168.178.43"/>
                        <TextBlock Text="Port"/>
                        <TextBox Watermark="22"/>
                        <TextBlock Text="Username"/>
                        <TextBox Watermark="root"/>
                        <TextBlock Text="Password"/>
                        <TextBox Watermark="iLoveAdmins" PasswordChar="•" />
                
                        <Button Content="Connect" Background="MediumTurquoise"/>
                </StackPanel>
        </Border>
</Window>
